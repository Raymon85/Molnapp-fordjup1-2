@model IEnumerable<RecruitmentPortal.Models.JobPosting>

@{
    ViewData["Title"] = "Job Openings";
}

<h1>Job Openings</h1>

<form method="get" class="d-flex mb-4 gap-2">
    <input type="search" name="search" value="@ViewBag.Search" class="form-control" placeholder="Search by title, department or location..." />
    <button type="submit" class="btn btn-primary">Search</button>
    @if (!string.IsNullOrEmpty(ViewBag.Search as string))
    {
        <a href="@Url.Action("Index")" class="btn btn-outline-secondary">Clear</a>
    }
</form>

@if (!Model.Any())
{
    <div class="alert alert-info">No job postings found.</div>
}
else
{
    <div class="row g-3">
        @foreach (var job in Model)
        {
            <div class="col-md-6 col-lg-4">
                <div class="card h-100 shadow-sm">
                    <div class="card-body">
                        <h5 class="card-title">@job.Title</h5>
                        <p class="text-muted mb-1">
                            <small>@job.Department &bull; @job.Location</small>
                        </p>
                        <p class="card-text">@(job.Description.Length > 100 ? job.Description[..100] + "..." : job.Description)</p>
                    </div>
                    <div class="card-footer d-flex justify-content-between align-items-center">
                        <small class="text-muted">Posted @job.PostedAt.ToString("MMM dd, yyyy")</small>
                        <a asp-action="Details" asp-route-id="@job.Id" class="btn btn-sm btn-primary">View Details</a>
                    </div>
                </div>
            </div>
        }
    </div>
}
